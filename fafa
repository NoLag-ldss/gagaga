-- XeonScripts Loading Screen
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

-- Add Blur Effect
local blur = Instance.new("BlurEffect")
blur.Size = 15
blur.Parent = Lighting

-- Create ScreenGui
local gui = Instance.new("ScreenGui", playerGui)
gui.Name = "XeonLoading"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true

-- Main Panel
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 480, 0, 180)
frame.Position = UDim2.new(0.5, -240, 0.5, -90)
frame.BackgroundColor3 = Color3.fromRGB(18, 15, 25)
frame.BackgroundTransparency = 0.05
frame.BorderSizePixel = 0

Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 16)

-- Frame Stroke
local frameStroke = Instance.new("UIStroke", frame)
frameStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
frameStroke.Color = Color3.fromRGB(138, 43, 226)
frameStroke.Thickness = 2
frameStroke.Transparency = 0.3

-- Shadow
local shadow = Instance.new("ImageLabel", frame)
shadow.Image = "rbxassetid://1316045217"
shadow.ImageColor3 = Color3.fromRGB(138, 43, 226)
shadow.ImageTransparency = 0.8
shadow.Size = UDim2.new(1, 100, 1, 100)
shadow.Position = UDim2.new(0.5, -290, 0.5, -140)
shadow.BackgroundTransparency = 1
shadow.ZIndex = -1

-- Cat Logo
local catLogo = Instance.new("TextLabel", frame)
catLogo.Size = UDim2.new(0, 60, 0, 60)
catLogo.Position = UDim2.new(0, 20, 0, 15)
catLogo.Text = "🐱"
catLogo.TextColor3 = Color3.fromRGB(186, 85, 211)
catLogo.TextScaled = true
catLogo.BackgroundTransparency = 1
catLogo.Font = Enum.Font.FredokaOne

-- Cat Logo Glow Animation
task.spawn(function()
    while catLogo and catLogo.Parent do
        TweenService:Create(catLogo, TweenInfo.new(1.5, Enum.EasingStyle.Sine), {
            TextColor3 = Color3.fromRGB(220, 120, 255)
        }):Play()
        task.wait(1.5)
        TweenService:Create(catLogo, TweenInfo.new(1.5, Enum.EasingStyle.Sine), {
            TextColor3 = Color3.fromRGB(138, 43, 226)
        }):Play()
        task.wait(1.5)
    end
end)

-- Glowing Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, -100, 0, 50)
title.Position = UDim2.new(0, 90, 0, 20)
title.Text = "XeonScripts"
title.TextColor3 = Color3.fromRGB(186, 85, 211)
title.TextTransparency = 0.1
title.TextStrokeColor3 = Color3.fromRGB(138, 43, 226)
title.TextStrokeTransparency = 0.5
title.Font = Enum.Font.FredokaOne
title.TextScaled = true
title.BackgroundTransparency = 1

-- Title Pulse Animation
task.spawn(function()
    while title and title.Parent do
        TweenService:Create(title, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {
            TextTransparency = 0.05,
            TextStrokeTransparency = 0.3
        }):Play()
        task.wait(1.2)
        TweenService:Create(title, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {
            TextTransparency = 0.25,
            TextStrokeTransparency = 0.7
        }):Play()
        task.wait(1.2)
    end
end)

-- Subtitle
local subtitle = Instance.new("TextLabel", frame)
subtitle.Size = UDim2.new(1, -100, 0, 20)
subtitle.Position = UDim2.new(0, 90, 0, 65)
subtitle.Text = "Garden Scripts & More"
subtitle.TextColor3 = Color3.fromRGB(150, 120, 180)
subtitle.TextTransparency = 0.3
subtitle.Font = Enum.Font.Gotham
subtitle.TextScaled = true
subtitle.BackgroundTransparency = 1

-- Loading Dots Animation
local loading = Instance.new("TextLabel", frame)
loading.Size = UDim2.new(1, -40, 0, 25)
loading.Position = UDim2.new(0, 20, 0, 95)
loading.Text = "Loading Scripts"
loading.TextColor3 = Color3.fromRGB(200, 180, 220)
loading.Font = Enum.Font.Gotham
loading.TextScaled = true
loading.BackgroundTransparency = 1

-- Dots Cycle
task.spawn(function()
    local dots = {"", ".", "..", "..."}
    local index = 1
    while loading and loading.Parent do
        loading.Text = "Loading Scripts" .. dots[index]
        index = (index % #dots) + 1
        task.wait(0.5)
    end
end)

-- Loading Bar Background
local barBg = Instance.new("Frame", frame)
barBg.Size = UDim2.new(1, -40, 0, 20)
barBg.Position = UDim2.new(0, 20, 1, -45)
barBg.BackgroundColor3 = Color3.fromRGB(30, 25, 40)
barBg.BorderSizePixel = 0
Instance.new("UICorner", barBg).CornerRadius = UDim.new(0, 10)

-- Loading Bar Fill
local barFill = Instance.new("Frame", barBg)
barFill.Size = UDim2.new(0, 0, 1, 0)
barFill.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
barFill.BorderSizePixel = 0
Instance.new("UICorner", barFill).CornerRadius = UDim.new(0, 10)

-- Purple Gradient Fill
local grad = Instance.new("UIGradient", barFill)
grad.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(220, 120, 255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(186, 85, 211)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(138, 43, 226))
}
grad.Transparency = NumberSequence.new{
    NumberSequenceKeypoint.new(0, 0),
    NumberSequenceKeypoint.new(1, 0.1)
}

-- Percentage Display
local percentage = Instance.new("TextLabel", frame)
percentage.Size = UDim2.new(0, 60, 0, 20)
percentage.Position = UDim2.new(1, -75, 1, -65)
percentage.Text = "0%"
percentage.TextColor3 = Color3.fromRGB(186, 85, 211)
percentage.Font = Enum.Font.GothamBold
percentage.TextScaled = true
percentage.BackgroundTransparency = 1
percentage.TextXAlignment = Enum.TextXAlignment.Right

-- Animate Fill with Percentage
task.spawn(function()
    for i = 0, 100 do
        local progress = i / 100
        TweenService:Create(barFill, TweenInfo.new(0.05, Enum.EasingStyle.Quad), {
            Size = UDim2.new(progress, 0, 1, 0)
        }):Play()
        percentage.Text = i .. "%"
        task.wait(0.05)
    end
end)

-- Optional: Soft chime sound
local sound = Instance.new("Sound", frame)
sound.SoundId = "rbxassetid://9118823106"
sound.Volume = 0.3
sound:Play()

-- Fade out and destroy after loading
task.delay(6, function()
    -- Fade out all elements
    TweenService:Create(frame, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(frameStroke, TweenInfo.new(0.8), {Transparency = 1}):Play()
    TweenService:Create(catLogo, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(title, TweenInfo.new(0.8), {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
    TweenService:Create(subtitle, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(loading, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(percentage, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
    TweenService:Create(barFill, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(barBg, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
    TweenService:Create(shadow, TweenInfo.new(0.8), {ImageTransparency = 1}):Play()
    
    -- Remove blur
    TweenService:Create(blur, TweenInfo.new(0.8), {Size = 0}):Play()
    
    task.wait(1)
    blur:Destroy()
    gui:Destroy()
    
    -- Your code continues here after loading screen
   loadstring(game:HttpGet("https://raw.githubusercontent.com/NoLag-ldss/gagaga/refs/heads/main/HGS",true))()
end)

print("✅ XeonScripts Loading Screen initialized!")
